# Backend API (optional). In dev, leave this unset so the app calls /api on the Vite dev server,
# which proxies to http://127.0.0.1:5000 and avoids CORS. Only set a full URL if you need a remote API.
# VITE_API_BASE_URL=http://localhost:5000/api

# Supabase (required for product data; without these, app uses local fallback in dev)
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Catalog ads & analytics (browser) ---
# Meta Pixel ID (Events Manager → Data sources → Pixel)
# VITE_META_PIXEL_ID=your_pixel_id

# Google Analytics 4 measurement ID (Admin → Data streams)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Server-only (Vercel → Project → Settings → Environment Variables) ---
# Supabase service role for feed generation (read products; never expose to client)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Meta Conversions API (server-side purchase events; pairs with VITE_META_PIXEL_ID)
# META_PIXEL_ID=your_pixel_id
# META_ACCESS_TOKEN=your_system_user_or_capi_token
