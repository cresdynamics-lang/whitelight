# Backend API (optional). In dev, leave this unset so the app calls /api on the Vite dev server,
# which proxies to http://127.0.0.1:5000 and avoids CORS. Only set a full URL if you need a remote API.
# VITE_API_BASE_URL=http://localhost:5000/api

# Supabase (required for product data; without these, app uses local fallback in dev)
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key
